LOG_LEVEL=info

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=readonly_user
POSTGRES_PASSWORD=replace-me
POSTGRES_DATABASE=app_db
POSTGRES_SSLMODE=require

POSTGRES_CONNECT_TIMEOUT=10s
POSTGRES_QUERY_TIMEOUT=15s
POSTGRES_MAX_OPEN_CONNS=4
POSTGRES_MAX_IDLE_CONNS=2
POSTGRES_CONN_MAX_LIFETIME=10m
POSTGRES_CONN_MAX_IDLE_TIME=5m
POSTGRES_MAX_ROWS=200
POSTGRES_MAX_BYTES=131072
POSTGRES_MAX_CELL_CHARS=2048

POSTGRES_ENABLE_WRITE=false
POSTGRES_WRITE_ACK=
