LOG_LEVEL=info

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=readonly_user
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=app_db
MYSQL_TLS=true

MYSQL_CONNECT_TIMEOUT=10s
MYSQL_QUERY_TIMEOUT=15s
MYSQL_MAX_OPEN_CONNS=4
MYSQL_MAX_IDLE_CONNS=2
MYSQL_CONN_MAX_LIFETIME=10m
MYSQL_CONN_MAX_IDLE_TIME=5m
MYSQL_MAX_ROWS=200
MYSQL_MAX_BYTES=131072
MYSQL_MAX_CELL_CHARS=2048

MYSQL_ENABLE_WRITE=false
MYSQL_WRITE_ACK=
