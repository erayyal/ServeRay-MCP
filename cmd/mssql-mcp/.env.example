LOG_LEVEL=info

MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=readonly_user
MSSQL_PASSWORD=replace-me
MSSQL_DATABASE=app_db
MSSQL_ENCRYPT=true

MSSQL_CONNECT_TIMEOUT=10s
MSSQL_QUERY_TIMEOUT=15s
MSSQL_MAX_OPEN_CONNS=4
MSSQL_MAX_IDLE_CONNS=2
MSSQL_CONN_MAX_LIFETIME=10m
MSSQL_CONN_MAX_IDLE_TIME=5m
MSSQL_MAX_ROWS=200
MSSQL_MAX_BYTES=131072
MSSQL_MAX_CELL_CHARS=2048

MSSQL_ENABLE_WRITE=false
MSSQL_WRITE_ACK=
