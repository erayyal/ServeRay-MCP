# ServeRay MCP root example file.
# Copy the server-specific file from cmd/<server>/.env.example for actual use.

LOG_LEVEL=info

# Example: MSSQL
# MSSQL_HOST=localhost
# MSSQL_PORT=1433
# MSSQL_USER=readonly_user
# MSSQL_PASSWORD=replace-me
# MSSQL_DATABASE=app_db

# Example: Filesystem
# FILESYSTEM_ALLOWED_ROOTS=repo=/absolute/path/to/repo
